# Biflorica
BIFLORICA_EMAIL=you@example.com
BIFLORICA_PASSWORD=secret

# Почта (IMAP) — Яндекс
# https://yandex.ru/support/mail/mail-clients/imap.html
MAIL_EMAIL=you@yandex.ru
MAIL_PASSWORD=your-password-or-app-password
# MAIL_IMAP_HOST=imap.yandex.ru

# Сервер UI
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# Playwright: true для сервера, false — видеть браузер при отладке
PLAYWRIGHT_HEADLESS=true
